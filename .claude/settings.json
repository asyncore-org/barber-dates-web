{
  "permissions": {
    "allow": [
      "Bash(pnpm dev)",
      "Bash(pnpm build)",
      "Bash(pnpm lint)",
      "Bash(pnpm lint *)",
      "Bash(pnpm type-check)",
      "Bash(pnpm test)",
      "Bash(pnpm test *)",
      "Bash(pnpm preview)",
      "Bash(pnpm analyze)",
      "Bash(pnpm run dev)",
      "Bash(pnpm run build)",
      "Bash(pnpm run lint)",
      "Bash(pnpm run lint *)",
      "Bash(pnpm run type-check)",
      "Bash(pnpm run test)",
      "Bash(pnpm run test *)",
      "Bash(pnpm run preview)",
      "Bash(pnpm run analyze)",
      "Bash(pnpm install)",
      "Bash(pnpm install *)",
      "Bash(pnpm install --frozen-lockfile)",
      "Bash(pnpm add *)",
      "Bash(pnpm add -D *)",
      "Bash(pnpm outdated)",
      "Bash(pnpm create vite@latest *)",
      "Bash(pnpm dlx shadcn@latest *)",
      "Bash(pnpm dlx shadcn-ui@latest *)",
      "Bash(pnpm dlx *)",
      "Bash(pnpm exec *)",
      "Bash(pnpm exec husky *)",
      "Bash(pnpm exec commitlint *)",
      "Bash(pnpm exec tsc *)",
      "Bash(pnpm exec vitest *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git add *)",
      "Bash(git stash *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git merge *)",
      "Bash(git rev-parse *)",
      "Bash(git cherry-pick *)",
      "Bash(git worktree *)",
      "Bash(bash .claude/scripts/*)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(node *)",
      "Bash(which *)",
      "Bash(pwd)",
      "Bash(chmod +x *)",
      "Bash(jq *)",
      "Bash(curl *)",
      "Bash(kill *)",
      "Bash(lsof *)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(git commit --no-verify*)",
      "Bash(git commit -n*)",
      "Bash(git push origin main*)",
      "Bash(git branch -D *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/session-start.sh\"",
            "blocking": false,
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/log-file-change.sh\"",
            "blocking": false,
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/context-watch.sh\"",
            "blocking": false,
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "file=\"$CLAUDE_TOOL_INPUT_FILE_PATH\"; if [[ \"$file\" == *.ts || \"$file\" == *.tsx ]]; then cd \"$CLAUDE_PROJECT_DIR\" && [ -f package.json ] && pnpm run type-check 2>&1 | tail -20 || true; fi",
            "blocking": false,
            "timeout": 30000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/pre-commit-check.sh\"",
            "blocking": false,
            "timeout": 3000
          }
        ]
      }
    ]
  }
}
